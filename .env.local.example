# Contact form — Resend (https://resend.com)
# 1. Create a free account at resend.com
# 2. Get your API key from the dashboard
# 3. (Optional) Verify a custom domain to send from your own address
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address to send FROM (must be a verified sender in Resend)
# Use "onboarding@resend.dev" for testing (only works for your Resend account email)
# Use onboarding@resend.dev (free plan, sends to your own email only)
# Or verify your domain in Resend and use: noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# Google reCAPTCHA v3 — https://www.google.com/recaptcha/admin/
# 1. Create a new site, choose "reCAPTCHA v3"
# 2. Add your domains: lichosik.dev + localhost
# 3. Copy the Site Key (public) and Secret Key (private)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Le_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_SECRET_KEY=6Le_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Search Console domain verification (optional)
# NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxx
